# ── MySQL ────────────────────────────────────────
MYSQL_HOST=db
MYSQL_DATABASE=vite_et_gourmand
MYSQL_USER=
MYSQL_PASSWORD=

# ── MongoDB ──────────────────────────────────────
MONGO_URI=mongodb://user:password@mongo:27017/vite_et_gourmand?authSource=admin

# ── Application ──────────────────────────────────
APP_ENV=local
APP_URL=http://localhost:8080

# ── Mail (Mailtrap pour le développement) ────────
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@viteetgourmand.fr
MAIL_FROM_NAME="Vite & Gourmand"